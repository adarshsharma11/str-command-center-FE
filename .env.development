# Development environment configuration
# This file is automatically loaded when running `npm run dev`

# Enable dev mode to bypass authentication and use mock data
VITE_DEV_MODE=true

# API Base URL (not used in dev mode since we use mock data)
# VITE_API_BASE_URL=http://localhost:3000

# Inactivity logout timeout in milliseconds (24 hours)
VITE_INACTIVITY_LOGOUT_MS=86400000
